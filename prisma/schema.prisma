generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  leads     Lead[]
}

model Provider {
  id                Int                 @id @default(autoincrement())
  name              String
  monthlyQuota      Int                 @default(10)
  leadsReceived     Int                 @default(0)

  assignments       LeadAssignment[]
}

model Lead {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  city        String
  description String

  serviceId   Int
  service     Service  @relation(fields: [serviceId], references: [id])

  createdAt   DateTime @default(now())

  assignments LeadAssignment[]

  @@unique([phone, serviceId])
}

model LeadAssignment {
  id          Int       @id @default(autoincrement())

  leadId      Int
  providerId  Int

  lead         Lead      @relation(fields: [leadId], references: [id])
  provider     Provider  @relation(fields: [providerId], references: [id])

  assignedAt   DateTime  @default(now())

  @@unique([leadId, providerId])
}

model AllocationState {
  id            Int @id @default(1)

  service1Index Int @default(0)
  service2Index Int @default(0)
  service3Index Int @default(0)
}

model WebhookEvent {
  id          Int      @id @default(autoincrement())

  eventId     String   @unique
  processedAt DateTime @default(now())
}